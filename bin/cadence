#!/usr/bin/env bash
# Cadence CLI entry point.
# Resolves this script's real path so it works when symlinked into PATH.

set -euo pipefail

resolve_link() {
  local path="$1"
  while [[ -L "$path" ]]; do
    local target
    target="$(readlink "$path")"
    if [[ "$target" = /* ]]; then
      path="$target"
    else
      path="$(cd "$(dirname "$path")" && cd "$(dirname "$target")" && pwd)/$(basename "$target")"
    fi
  done
  printf '%s\n' "$path"
}

SELF="$(resolve_link "${BASH_SOURCE[0]}")"
CADENCE_ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"
export CADENCE_ROOT

usage() {
  cat <<EOF
Cadence — project-level skills/hooks manager

Usage:
  cadence install [path]     Install Cadence into a project (default: \$PWD)
  cadence uninstall [path]   Remove Cadence from a project (default: \$PWD)
  cadence -h, --help         Show this help

Home: $CADENCE_ROOT
EOF
}

cmd="${1:-}"
[[ $# -gt 0 ]] && shift || true

case "$cmd" in
  install)
    exec bash "$CADENCE_ROOT/scripts/install.sh" "$@"
    ;;
  uninstall)
    exec bash "$CADENCE_ROOT/scripts/uninstall.sh" "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "cadence: unknown command '$cmd'" >&2
    echo "run 'cadence --help' for usage" >&2
    exit 1
    ;;
esac
